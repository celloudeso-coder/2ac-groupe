# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Nouvelle clé publishable (sb_publishable_...) — ou l'ancienne anon key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
# SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL=contact@2ac-gn.com
# Expéditeur : onboarding@resend.dev tant que le domaine n'est pas vérifié
RESEND_FROM=onboarding@resend.dev

# Site
NEXT_PUBLIC_SITE_URL=https://www.2ac-gn.com
